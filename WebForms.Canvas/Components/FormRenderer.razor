@using WebForms.Canvas.Forms
@using WebForms.Canvas.Drawing
@using BlazorMouseEventArgs = Microsoft.AspNetCore.Components.Web.MouseEventArgs
@using BlazorKeyboardEventArgs = Microsoft.AspNetCore.Components.Web.KeyboardEventArgs
@using BlazorTouchEventArgs = Microsoft.AspNetCore.Components.Web.TouchEventArgs
@inject IJSRuntime JSRuntime
@implements IDisposable

@if (Form != null && Form.Visible)
{
    <canvas @ref="_canvasRef" 
            @onmousedown="HandleMouseDown"
            @onmouseup="HandleMouseUp"
            @onmousemove="HandleMouseMove"
            @onmouseleave="HandleMouseLeave"
            @onmouseenter="HandleMouseEnter"
            @onclick="HandleClick"
            @ondblclick="HandleDoubleClick"
            @ontouchstart="HandleTouchStart"
            @ontouchmove="HandleTouchMove"
            @ontouchend="HandleTouchEnd"
            tabindex="0"
            @onkeydown="HandleKeyDown"
            @onkeyup="HandleKeyUp"
            @onkeypress="HandleKeyPress"
            width="@Form.Width" 
            height="@Form.Height"
            style="position: absolute; 
                   left: @(Form.Left)px;
                   top: @(Form.Top)px; 
                   z-index: @(Form.ZIndex);
                   display: block; 
                   outline: none;
                   cursor: @GetCanvasCursor();
                   user-select: none;
                   box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                   transition: @(_enableAnimation ? $"left {AnimationDurationMs}ms ease-out, top {AnimationDurationMs}ms ease-out, width {AnimationDurationMs}ms ease-out, height {AnimationDurationMs}ms ease-out" : "none");
                   will-change: @(_isResizing || _isDragging ? "transform" : "auto");">
    </canvas>

    @if (_showMaximizePreview)
    {
        <div style="position: fixed;
                    left: 0;
                    top: @(TaskbarHeight)px;
                    width: @(ViewportWidth)px;
                    height: @(ViewportHeight - TaskbarHeight)px;
                    border: 3px solid #4a90e2;
                    background-color: rgba(74, 144, 226, 0.1);
                    pointer-events: none;
                    z-index: 9999;
                    box-sizing: border-box;">
        </div>
    }
}

@code {
    [Parameter]
    public Form? Form { get; set; }

    private ElementReference _canvasRef;
    private bool _initialized = false;
    private DotNetObjectReference<FormRenderer>? _dotNetRef;

    // Form chrome dimensions
    private const int TitleBarHeight = 32;
    private const int BorderWidth = 2;
    private const int ResizeHandleSize = 8;
    private const int CloseButtonSize = 20;
    private const int CloseButtonMargin = 6;

    // Dragging state
    private bool _isDragging = false;
    private double _dragStartX = 0;
    private double _dragStartY = 0;
    private int _dragFormStartLeft = 0;  // Position when drag started (for delta calc)
    private int _dragFormStartTop = 0;   // Position when drag started (for delta calc)

    // Pre-drag bounds (for snap-to-maximize restore)
    private int _preDragLeft = 0;
    private int _preDragTop = 0;
    private int _preDragWidth = 0;
    private int _preDragHeight = 0;
    private bool _preDragBoundsSaved = false;

    // Resizing state
    private bool _isResizing = false;
    private ResizeDirection _resizeDirection = ResizeDirection.None;
    private double _resizeStartX = 0;
    private double _resizeStartY = 0;
    private int _resizeFormStartWidth = 0;
    private int _resizeFormStartHeight = 0;
    private int _resizeFormStartLeft = 0;
    private int _resizeFormStartTop = 0;

    // Throttling for resize rendering
    private DateTime _lastResizeRender = DateTime.MinValue;
    private const int ResizeRenderThrottleMs = 16; // ~60 FPS

    // Render queue for keyboard input
    private bool _renderPending = false;

    // Coalescing for control invalidations
    private bool _renderQueued = false;
    private bool _renderRequested = false;

    // Touch state
    private double _lastTouchX = 0;
    private double _lastTouchY = 0;

    // Hover state for window control buttons and cursor
    private bool _closeButtonHover = false;
    private bool _minimizeButtonHover = false;
    private bool _maximizeButtonHover = false;
    private int _lastMouseX = 0;
    private int _lastMouseY = 0;

    // Animation state
    private bool _enableAnimation = false;
    private const int AnimationDurationMs = 200; // Low priority, quick animation

    // Snap-to-maximize state
    private bool _showMaximizePreview = false;
    private const int SnapToTopThreshold = 5; // Pixels from top to trigger snap

    private enum ResizeDirection
    {
        None,
        Left,
        Right,
        Top,
        Bottom,
        TopLeft,
        TopRight,
        BottomLeft,
        BottomRight
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Form == null) return;

        if (firstRender)
        {
            _initialized = true;

            // Initialize text measurement service
            Form.TextMeasurementService = new TextMeasurementService(JSRuntime);

            // Set RequestRender and propagate to all children
            var renderFunc = () =>
            {
                // Coalesce multiple invalidations into at most one render per tick.
                // This significantly reduces flicker when controls trigger multiple Invalidate() calls
                // during a single input sequence (mouse down/up, focus change, CheckedChanged, etc.).
                _renderRequested = true;
                if (_renderQueued)
                {
                    return Task.CompletedTask;
                }

                _renderQueued = true;

                _ = InvokeAsync(async () =>
                {
                    // Process renders until no more invalidations were requested.
                    while (_renderRequested)
                    {
                        _renderRequested = false;

                        // Yield so multiple invalidations within the same call stack batch together.
                        await Task.Yield();

                        // Only render if canvas ref is still valid and form is still visible
                        if (_canvasRef.Id != null && Form?.Visible == true)
                        {
                            await RenderForm();
                        }
                    }

                    _renderQueued = false;
                });

                return Task.CompletedTask;
            };

            Form.PropagateRequestRender(renderFunc);

            _dotNetRef = DotNetObjectReference.Create(this);
        }

        // Always render the form after any render cycle if initialized and visible
        if (_initialized && Form.Visible)
        {
            await RenderForm();
        }
    }
    private async Task RenderForm()
    {
        // Don't render if not initialized, form is null, or form is not visible
        if (!_initialized || Form == null || !Form.Visible) return;

        // Prevent overlapping renders
        if (_renderPending) return;
        _renderPending = true;

        try
        {
            // Verify canvas reference is still valid
            if (_canvasRef.Id == null)
            {
                Console.WriteLine("RenderForm: Canvas reference is invalid, skipping render");
                _renderPending = false;
                return;
            }

            // First, render the form chrome (title bar, border, window control buttons)
            await JSRuntime.InvokeVoidAsync("renderFormCanvas", _canvasRef, 
                Form.Width,
                Form.Height,
                Form.Text,
                Form.BackColor.ToHexString(),
                BorderWidth,
                TitleBarHeight + BorderWidth,
                Form.Width - (BorderWidth * 2),
                Form.Height - TitleBarHeight - (BorderWidth * 2),
                _closeButtonHover,
                _minimizeButtonHover,
                _maximizeButtonHover,
                Form.WindowState == FormWindowState.Maximized);

            // Create graphics for client area (size excludes chrome)
            using var graphics = new Graphics(
                Form.Width - (BorderWidth * 2), 
                Form.Height - TitleBarHeight - (BorderWidth * 2)
            );

            // Clear client area with background color
            graphics.Clear(Form.BackColor);

            // Trigger Paint event to let user code draw
            var paintArgs = new PaintEventArgs(
                graphics, 
                new Rectangle(0, 0, 
                    Form.Width - (BorderWidth * 2), 
                    Form.Height - TitleBarHeight - (BorderWidth * 2))
            );
            Form.OnPaint(paintArgs);

            // Execute drawing commands in client area (translated and clipped)
            var commands = graphics.GetCommands();
            var jsCommands = string.Join("\n", commands.Select(c => c.ToJavaScript()));

            await JSRuntime.InvokeVoidAsync("renderClientArea", _canvasRef, 
                BorderWidth, 
                TitleBarHeight + BorderWidth, 
                jsCommands);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"RenderForm error: {ex.Message}");
        }
        finally
        {
            _renderPending = false;
        }
    }

    // Bring form to front when clicked (synchronous version for drag/resize)
    private void BringToFrontSync()
    {
        if (Form == null) return;

        var oldZIndex = Form.ZIndex;
        var currentMaxZIndex = GetMaxZIndex?.Invoke() ?? 0;

        // Only increment z-index if not already at front
        var changed = Form.BringToFrontIfNeeded(currentMaxZIndex);

        if (changed)
        {
            _ = JSRuntime.InvokeVoidAsync("console.log", 
                $"BringToFront: '{Form.Text}' z-index {oldZIndex} → {Form.ZIndex}");
        }
        else
        {
            _ = JSRuntime.InvokeVoidAsync("console.log", 
                $"BringToFront: '{Form.Text}' already at front (z-index {Form.ZIndex})");
        }
    }

    // Hit-testing helpers
    private Rectangle GetCloseButtonRect()
    {
        if (Form == null) return new Rectangle(0, 0, 0, 0);

        var x = Form.Width - CloseButtonSize - CloseButtonMargin;
        var y = (TitleBarHeight - CloseButtonSize) / 2 + BorderWidth;
        return new Rectangle(x, y, CloseButtonSize, CloseButtonSize);
    }

    private Rectangle GetMaximizeButtonRect()
    {
        if (Form == null) return new Rectangle(0, 0, 0, 0);

        var closeButtonX = Form.Width - CloseButtonSize - CloseButtonMargin;
        var x = closeButtonX - CloseButtonSize - 4;
        var y = (TitleBarHeight - CloseButtonSize) / 2 + BorderWidth;
        return new Rectangle(x, y, CloseButtonSize, CloseButtonSize);
    }

    private Rectangle GetMinimizeButtonRect()
    {
        if (Form == null) return new Rectangle(0, 0, 0, 0);

        var maximizeButtonRect = GetMaximizeButtonRect();
        var x = maximizeButtonRect.X - CloseButtonSize - 4;
        var y = (TitleBarHeight - CloseButtonSize) / 2 + BorderWidth;
        return new Rectangle(x, y, CloseButtonSize, CloseButtonSize);
    }

    private bool IsPointInRect(int x, int y, Rectangle rect)
    {
        return x >= rect.X && x < rect.X + rect.Width &&
               y >= rect.Y && y < rect.Y + rect.Height;
    }

    private ResizeDirection GetResizeDirection(int x, int y)
    {
        if (Form == null || !Form.AllowResize) return ResizeDirection.None;

        var handleSize = ResizeHandleSize;
        var width = Form.Width;
        var height = Form.Height;

        // Check corners first (they have priority)
        if (x < handleSize && y < handleSize) return ResizeDirection.TopLeft;
        if (x >= width - handleSize && y < handleSize) return ResizeDirection.TopRight;
        if (x < handleSize && y >= height - handleSize) return ResizeDirection.BottomLeft;
        if (x >= width - handleSize && y >= height - handleSize) return ResizeDirection.BottomRight;

        // Check edges
        if (x < handleSize) return ResizeDirection.Left;
        if (x >= width - handleSize) return ResizeDirection.Right;
        if (y < handleSize) return ResizeDirection.Top;
        if (y >= height - handleSize) return ResizeDirection.Bottom;

        return ResizeDirection.None;
    }

    private string GetCanvasCursor()
    {
        if (_isDragging) return "move";
        if (_isResizing) return GetResizeCursor(_resizeDirection);

        // Check if mouse is over resize handles
        if (Form != null && Form.AllowResize)
        {
            var resizeDir = GetResizeDirection(_lastMouseX, _lastMouseY);
            if (resizeDir != ResizeDirection.None)
            {
                return GetResizeCursor(resizeDir);
            }
        }

        // Check if mouse is over title bar (draggable area)
        if (Form != null && Form.AllowMove && _lastMouseY < TitleBarHeight + BorderWidth && _lastMouseY >= BorderWidth)
        {
            // Not over any window control buttons
            var closeButtonRect = GetCloseButtonRect();
            var maximizeButtonRect = GetMaximizeButtonRect();
            var minimizeButtonRect = GetMinimizeButtonRect();
            if (!IsPointInRect(_lastMouseX, _lastMouseY, closeButtonRect) &&
                !IsPointInRect(_lastMouseX, _lastMouseY, maximizeButtonRect) &&
                !IsPointInRect(_lastMouseX, _lastMouseY, minimizeButtonRect))
            {
                return "move";
            }
        }

        return "default";
    }

    private string GetResizeCursor(ResizeDirection direction)
    {
        return direction switch
        {
            ResizeDirection.Left or ResizeDirection.Right => "ew-resize",
            ResizeDirection.Top or ResizeDirection.Bottom => "ns-resize",
            ResizeDirection.TopLeft or ResizeDirection.BottomRight => "nwse-resize",
            ResizeDirection.TopRight or ResizeDirection.BottomLeft => "nesw-resize",
            _ => "default"
        };
    }

    // Dragging
    private async void StartDrag(BlazorMouseEventArgs e)
    {
        if (Form == null || !Form.AllowMove || _dotNetRef == null) return;

        BringToFrontSync();

        // Save the pre-drag bounds for potential snap-to-maximize restore
        // This ensures we restore to the position BEFORE dragging started
        _preDragLeft = Form.Left;
        _preDragTop = Form.Top;
        _preDragWidth = Form.Width;
        _preDragHeight = Form.Height;
        _preDragBoundsSaved = true;

        // If window is maximized, restore it first (Windows-style behavior)
        if (Form.WindowState == FormWindowState.Maximized)
        {
            // For maximized windows, the pre-drag bounds should be the stored normal bounds
            // (not the maximized position), so don't use current position
            _preDragBoundsSaved = false; // Let Maximize use its own saved bounds

            // Calculate where the mouse is relative to the window width
            var mouseXRatio = e.OffsetX / Form.Width;

            // Restore the window
            Form.Restore();

            // Trigger layout update after restore
            Form.PerformLayout();

            // Adjust the starting position so the mouse stays under the same relative position
            // This makes the window "stick" to the cursor when dragging from maximized
            var newLeft = (int)(e.ClientX - (Form.Width * mouseXRatio));
            var newTop = 0; // Start at top of desktop area

            // Set the form to the calculated position immediately
            Form.Left = newLeft;
            Form.Top = newTop;

            // Force multiple state updates to ensure Blazor picks up the changes
            StateHasChanged();
            await Task.Yield(); // Yield to allow Blazor to process
            StateHasChanged();
            await RenderForm();
            StateHasChanged();
        }

        await JSRuntime.InvokeVoidAsync("setActiveFormRenderer", _dotNetRef);

        _isDragging = true;
        _dragStartX = e.ClientX;
        _dragStartY = e.ClientY;
        _dragFormStartLeft = Form.Left;
        _dragFormStartTop = Form.Top;

        StateHasChanged();
    }

    private async Task StartResize(BlazorMouseEventArgs e, ResizeDirection direction)
    {
        if (Form == null || !Form.AllowResize || _dotNetRef == null) return;

        BringToFrontSync();

        await JSRuntime.InvokeVoidAsync("setActiveFormRenderer", _dotNetRef);

        _isResizing = true;
        _resizeDirection = direction;
        _resizeStartX = e.ClientX;
        _resizeStartY = e.ClientY;
        _resizeFormStartWidth = Form.Width;
        _resizeFormStartHeight = Form.Height;
        _resizeFormStartLeft = Form.Left;
        _resizeFormStartTop = Form.Top;

        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnGlobalMouseMove(double clientX, double clientY)
    {
        if (Form == null) return;
        if (_isDragging)
        {
            var deltaX = (int)(clientX - _dragStartX);
            var deltaY = (int)(clientY - _dragStartY);
            Form.Left = _dragFormStartLeft + deltaX;
            Form.Top = _dragFormStartTop + deltaY;

            // Check for snap-to-top maximize (only for normal windows)
            if (Form.WindowState == FormWindowState.Normal)
            {
                // Calculate actual screen Y position
                var screenY = clientY - TaskbarHeight;

                if (screenY <= SnapToTopThreshold && !_showMaximizePreview)
                {
                    // Show maximize preview
                    _showMaximizePreview = true;
                }
                else if (screenY > SnapToTopThreshold && _showMaximizePreview)
                {
                    // Hide maximize preview
                    _showMaximizePreview = false;
                }
            }

            StateHasChanged();
        }
        else if (_isResizing)
        {
            var deltaX = (int)(clientX - _resizeStartX);
            var deltaY = (int)(clientY - _resizeStartY);

            switch (_resizeDirection)
            {
                case ResizeDirection.Left:
                    {
                        var newWidth = _resizeFormStartWidth - deltaX;
                        var minWidth = Math.Max(Form.MinimumWidth, 100);
                        newWidth = Math.Max(minWidth, newWidth);
                        if (Form.MaximumWidth > 0) newWidth = Math.Min(Form.MaximumWidth, newWidth);

                        var actualDelta = _resizeFormStartWidth - newWidth;
                        var newLeft = _resizeFormStartLeft + actualDelta;

                        Form.Width = newWidth;
                        Form.Left = newLeft;
                    }
                    break;

                case ResizeDirection.Right:
                    {
                        var minWidth = Math.Max(Form.MinimumWidth, 100);
                        var newWidth = Math.Max(minWidth, _resizeFormStartWidth + deltaX);
                        if (Form.MaximumWidth > 0) newWidth = Math.Min(newWidth, Form.MaximumWidth);
                        Form.Width = newWidth;
                    }
                    break;

                case ResizeDirection.Top:
                    {
                        var newHeight = _resizeFormStartHeight - deltaY;
                        var minHeight = Math.Max(Form.MinimumHeight, TitleBarHeight + 50);
                        newHeight = Math.Max(minHeight, newHeight);
                        if (Form.MaximumHeight > 0) newHeight = Math.Min(Form.MaximumHeight, newHeight);

                        var actualDelta = _resizeFormStartHeight - newHeight;
                        var newTop = _resizeFormStartTop + actualDelta;

                        Form.Height = newHeight;
                        Form.Top = newTop;
                    }
                    break;

                case ResizeDirection.Bottom:
                    {
                        var minHeight = Math.Max(Form.MinimumHeight, TitleBarHeight + 50);
                        var newHeight = Math.Max(minHeight, _resizeFormStartHeight + deltaY);
                        if (Form.MaximumHeight > 0) newHeight = Math.Min(newHeight, Form.MaximumHeight);
                        Form.Height = newHeight;
                    }
                    break;

                case ResizeDirection.TopLeft:
                    {
                        var newWidth = _resizeFormStartWidth - deltaX;
                        newWidth = Math.Max(Math.Max(Form.MinimumWidth, 100), newWidth);
                        if (Form.MaximumWidth > 0) newWidth = Math.Min(Form.MaximumWidth, newWidth);
                        var actualDeltaX = _resizeFormStartWidth - newWidth;
                        var newLeft = _resizeFormStartLeft + actualDeltaX;

                        var newHeight = _resizeFormStartHeight - deltaY;
                        newHeight = Math.Max(Math.Max(Form.MinimumHeight, TitleBarHeight + 50), newHeight);
                        if (Form.MaximumHeight > 0) newHeight = Math.Min(Form.MaximumHeight, newHeight);
                        var actualDeltaY = _resizeFormStartHeight - newHeight;
                        var newTop = _resizeFormStartTop + actualDeltaY;

                        Form.Width = newWidth;
                        Form.Left = newLeft;
                        Form.Height = newHeight;
                        Form.Top = newTop;
                    }
                    break;

                case ResizeDirection.TopRight:
                    {
                        var newWidth = Math.Max(Math.Max(Form.MinimumWidth, 100), _resizeFormStartWidth + deltaX);
                        if (Form.MaximumWidth > 0) newWidth = Math.Min(newWidth, Form.MaximumWidth);

                        var newHeight = _resizeFormStartHeight - deltaY;
                        newHeight = Math.Max(Math.Max(Form.MinimumHeight, TitleBarHeight + 50), newHeight);
                        if (Form.MaximumHeight > 0) newHeight = Math.Min(Form.MaximumHeight, newHeight);
                        var actualDeltaY = _resizeFormStartHeight - newHeight;
                        var newTop = _resizeFormStartTop + actualDeltaY;

                        Form.Width = newWidth;
                        Form.Height = newHeight;
                        Form.Top = newTop;
                    }
                    break;

                case ResizeDirection.BottomLeft:
                    {
                        var newWidth = _resizeFormStartWidth - deltaX;
                        newWidth = Math.Max(Math.Max(Form.MinimumWidth, 100), newWidth);
                        if (Form.MaximumWidth > 0) newWidth = Math.Min(Form.MaximumWidth, newWidth);
                        var actualDeltaX = _resizeFormStartWidth - newWidth;
                        var newLeft = _resizeFormStartLeft + actualDeltaX;

                        var newHeight = Math.Max(Math.Max(Form.MinimumHeight, TitleBarHeight + 50), _resizeFormStartHeight + deltaY);
                        if (Form.MaximumHeight > 0) newHeight = Math.Min(newHeight, Form.MaximumHeight);

                        Form.Width = newWidth;
                        Form.Left = newLeft;
                        Form.Height = newHeight;
                    }
                    break;

                case ResizeDirection.BottomRight:
                    {
                        var newWidth = Math.Max(Math.Max(Form.MinimumWidth, 100), _resizeFormStartWidth + deltaX);
                        var newHeight = Math.Max(Math.Max(Form.MinimumHeight, TitleBarHeight + 50), _resizeFormStartHeight + deltaY);
                        if (Form.MaximumWidth > 0) newWidth = Math.Min(newWidth, Form.MaximumWidth);
                        if (Form.MaximumHeight > 0) newHeight = Math.Min(newHeight, Form.MaximumHeight);

                        Form.Width = newWidth;
                        Form.Height = newHeight;
                    }
                    break;
            }

            var now = DateTime.UtcNow;
            var timeSinceLastRender = (now - _lastResizeRender).TotalMilliseconds;

            if (timeSinceLastRender >= ResizeRenderThrottleMs)
            {
                _lastResizeRender = now;
                StateHasChanged();
                await RenderForm();
            }
            else
            {
                // Still update the canvas size, just don't render content yet
                StateHasChanged();
            }
        }
    }

    [JSInvokable]
    public async Task OnGlobalMouseUp()
    {
        var wasResizing = _isResizing;
        var wasDragging = _isDragging;
        var shouldSnapMaximize = _showMaximizePreview && wasDragging;

        _isDragging = false;
        _isResizing = false;
        _resizeDirection = ResizeDirection.None;
        _showMaximizePreview = false; // Hide preview

        // Check if we should snap-to-maximize
        if (shouldSnapMaximize && Form != null)
        {
            // Save the pre-drag bounds before maximizing
            var savedLeft = _preDragLeft;
            var savedTop = _preDragTop;
            var savedWidth = _preDragWidth;
            var savedHeight = _preDragHeight;
            var shouldRestorePreDragBounds = _preDragBoundsSaved;

            // Maximize the form with animation
            await ToggleMaximize();

            // AFTER maximizing, set the normal bounds to the pre-drag position
            // This ensures restore goes back to where the form was BEFORE the user started dragging
            if (shouldRestorePreDragBounds && Form != null)
            {
                Form.SetNormalBounds(savedLeft, savedTop, savedWidth, savedHeight);
            }
        }
        else if (wasResizing || wasDragging)
        {
            // Ensure title bar is visible after moving or resizing
            if (Form != null && _dotNetRef != null)
            {
                await EnsureFormTitleBarVisible();
            }
        }

        // Reset pre-drag bounds tracking
        _preDragBoundsSaved = false;

        if (wasResizing)
        {
            // Trigger layout update after resize completes
            Form?.PerformLayout();
            await RenderForm();
        }

        if (wasResizing || wasDragging)
        {
            StateHasChanged();
        }
    }

    // Mouse events on canvas
    private async void HandleMouseDown(BlazorMouseEventArgs e)
    {
        if (Form == null) return;

        // Update modifier keys state for mouse events
        UpdateModifierKeys(e.CtrlKey, e.ShiftKey, e.AltKey);

        var x = (int)e.OffsetX;
        var y = (int)e.OffsetY;

        // Check close button
        var closeButtonRect = GetCloseButtonRect();
        if (IsPointInRect(x, y, closeButtonRect))
        {
            CloseForm();
            return;
        }

        // Check maximize button
        var maximizeButtonRect = GetMaximizeButtonRect();
        if (IsPointInRect(x, y, maximizeButtonRect))
        {
            await ToggleMaximize();
            return;
        }

        // Check minimize button
        var minimizeButtonRect = GetMinimizeButtonRect();
        if (IsPointInRect(x, y, minimizeButtonRect))
        {
            MinimizeForm();
            return;
        }

        // Check resize handles
        if (Form.AllowResize)
        {
            var resizeDir = GetResizeDirection(x, y);
            if (resizeDir != ResizeDirection.None)
            {
                await StartResize(e, resizeDir);
                return;
            }
        }

        // Check title bar for dragging
        if (Form.AllowMove && y < TitleBarHeight + BorderWidth)
        {
            StartDrag(e);
            return;
        }

        // Handle mouse down in client area
        BringToFrontSync();
        var clientX = x - BorderWidth;
        var clientY = y - TitleBarHeight - BorderWidth;

        if (clientX >= 0 && clientY >= 0 && 
            clientX < Form.Width - (BorderWidth * 2) && 
            clientY < Form.Height - TitleBarHeight - (BorderWidth * 2))
        {
            var args = new Forms.MouseEventArgs(
                GetMouseButton(e.Button),
                1,
                clientX,
                clientY
            );
            Form.OnMouseDown(args);
        }

        StateHasChanged();
    }

    private void HandleMouseUp(BlazorMouseEventArgs e)
    {
        if (Form == null) return;

        var x = (int)e.OffsetX;
        var y = (int)e.OffsetY;

        // Handle mouse up in client area
        var clientX = x - BorderWidth;
        var clientY = y - TitleBarHeight - BorderWidth;

        if (clientX >= 0 && clientY >= 0 && 
            clientX < Form.Width - (BorderWidth * 2) && 
            clientY < Form.Height - TitleBarHeight - (BorderWidth * 2))
        {
            var args = new Forms.MouseEventArgs(
                GetMouseButton(e.Button),
                1,
                clientX,
                clientY
            );
            Form.OnMouseUp(args);
        }
    }

    private async void HandleMouseMove(BlazorMouseEventArgs e)
    {
        if (Form == null) return;

        var x = (int)e.OffsetX;
        var y = (int)e.OffsetY;

        // Track mouse position for cursor updates
        var oldX = _lastMouseX;
        var oldY = _lastMouseY;
        _lastMouseX = x;
        _lastMouseY = y;

        // Check button hover states
        var closeButtonRect = GetCloseButtonRect();
        var maximizeButtonRect = GetMaximizeButtonRect();
        var minimizeButtonRect = GetMinimizeButtonRect();

        var wasCloseHovering = _closeButtonHover;
        var wasMaximizeHovering = _maximizeButtonHover;
        var wasMinimizeHovering = _minimizeButtonHover;

        _closeButtonHover = IsPointInRect(x, y, closeButtonRect);
        _maximizeButtonHover = IsPointInRect(x, y, maximizeButtonRect);
        _minimizeButtonHover = IsPointInRect(x, y, minimizeButtonRect);

        if (wasCloseHovering != _closeButtonHover || 
            wasMaximizeHovering != _maximizeButtonHover ||
            wasMinimizeHovering != _minimizeButtonHover)
        {
            await RenderForm();
        }

        // Check if we need to update cursor (moved into/out of resize or title bar area)
        var needsCursorUpdate = false;

        // Check if we crossed into/out of resize handle area
        if (Form.AllowResize)
        {
            var oldResizeDir = GetResizeDirection(oldX, oldY);
            var newResizeDir = GetResizeDirection(x, y);
            if (oldResizeDir != newResizeDir)
            {
                needsCursorUpdate = true;
            }
        }

        // Check if we crossed into/out of title bar
        if (Form.AllowMove)
        {
            var wasInTitleBar = oldY < TitleBarHeight + BorderWidth && oldY >= BorderWidth;
            var isInTitleBar = y < TitleBarHeight + BorderWidth && y >= BorderWidth;
            if (wasInTitleBar != isInTitleBar)
            {
                needsCursorUpdate = true;
            }
        }

        if (needsCursorUpdate)
        {
            StateHasChanged();
        }

        // Handle mouse move in client area
        var clientX = x - BorderWidth;
        var clientY = y - TitleBarHeight - BorderWidth;

        if (clientX >= 0 && clientY >= 0 && 
            clientX < Form.Width - (BorderWidth * 2) && 
            clientY < Form.Height - TitleBarHeight - (BorderWidth * 2))
        {
            var args = new Forms.MouseEventArgs(
                MouseButtons.None,
                0,
                clientX,
                clientY
            );
            Form.OnMouseMove(args);
        }
    }

    private void HandleMouseEnter(BlazorMouseEventArgs e)
    {
        if (Form == null) return;
        Form.OnMouseEnter(EventArgs.Empty);
    }

    private void HandleMouseLeave(BlazorMouseEventArgs e)
    {
        if (Form == null) return;
        _closeButtonHover = false;
        _lastMouseX = -1;
        _lastMouseY = -1;
        Form.OnMouseLeave(EventArgs.Empty);
        StateHasChanged(); // Update cursor to default
    }

    private void HandleClick(BlazorMouseEventArgs e)
    {
        if (Form == null) return;

        var x = (int)e.OffsetX;
        var y = (int)e.OffsetY;

        // Handle click in client area
        var clientX = x - BorderWidth;
        var clientY = y - TitleBarHeight - BorderWidth;

        if (clientX >= 0 && clientY >= 0 && 
            clientX < Form.Width - (BorderWidth * 2) && 
            clientY < Form.Height - TitleBarHeight - (BorderWidth * 2))
        {
            var args = new Forms.MouseEventArgs(
                GetMouseButton(e.Button),
                1,
                clientX,
                clientY
            );
            Form.OnMouseClick(args);
        }
    }

    private async void HandleDoubleClick(BlazorMouseEventArgs e)
    {
        if (Form == null) return;

        var x = (int)e.OffsetX;
        var y = (int)e.OffsetY;

        // Check if double-click is on title bar (excluding window control buttons)
        if (y < TitleBarHeight + BorderWidth && y >= BorderWidth)
        {
            // Check if not clicking on window control buttons
            var closeButtonRect = GetCloseButtonRect();
            var maximizeButtonRect = GetMaximizeButtonRect();
            var minimizeButtonRect = GetMinimizeButtonRect();

            if (!IsPointInRect(x, y, closeButtonRect) &&
                !IsPointInRect(x, y, maximizeButtonRect) &&
                !IsPointInRect(x, y, minimizeButtonRect))
            {
                // Double-click on title bar - toggle maximize/restore
                await ToggleMaximize();
                return;
            }
        }

        // Handle double click in client area
        var clientX = x - BorderWidth;
        var clientY = y - TitleBarHeight - BorderWidth;

        if (clientX >= 0 && clientY >= 0 && 
            clientX < Form.Width - (BorderWidth * 2) && 
            clientY < Form.Height - TitleBarHeight - (BorderWidth * 2))
        {
            var args = new Forms.MouseEventArgs(
                GetMouseButton(e.Button),
                2,
                clientX,
                clientY
            );
            Form.OnMouseDoubleClick(args);
        }
    }

    // Touch events - map to canvas coordinates
    private async void HandleTouchStart(BlazorTouchEventArgs e)
    {
        if (Form == null || e.Touches.Length == 0) return;

        var touch = e.Touches[0];
        _lastTouchX = touch.ClientX;
        _lastTouchY = touch.ClientY;

        // Get canvas bounds for coordinate conversion
        var canvasBounds = await JSRuntime.InvokeAsync<BoundingRect>("getCanvasBounds", _canvasRef);
        var x = (int)(touch.ClientX - canvasBounds.Left);
        var y = (int)(touch.ClientY - canvasBounds.Top);

        // Check close button
        var closeButtonRect = GetCloseButtonRect();
        if (IsPointInRect(x, y, closeButtonRect))
        {
            CloseForm();
            return;
        }

        // Check resize handles
        if (Form.AllowResize)
        {
            var resizeDir = GetResizeDirection(x, y);
            if (resizeDir != ResizeDirection.None)
            {
                // Touch resize not fully implemented - can be added later
                return;
            }
        }

        // Map to client coordinates
        var clientX = x - BorderWidth;
        var clientY = y - TitleBarHeight - BorderWidth;

        if (clientX >= 0 && clientY >= 0 && 
            clientX < Form.Width - (BorderWidth * 2) && 
            clientY < Form.Height - TitleBarHeight - (BorderWidth * 2))
        {
            var args = new Forms.MouseEventArgs(
                MouseButtons.Left,
                1,
                clientX,
                clientY
            );
            Form.OnMouseDown(args);
        }
    }

    private async void HandleTouchMove(BlazorTouchEventArgs e)
    {
        if (Form == null || e.Touches.Length == 0) return;

        var touch = e.Touches[0];
        var canvasBounds = await JSRuntime.InvokeAsync<BoundingRect>("getCanvasBounds", _canvasRef);
        var x = (int)(touch.ClientX - canvasBounds.Left);
        var y = (int)(touch.ClientY - canvasBounds.Top);

        var clientX = x - BorderWidth;
        var clientY = y - TitleBarHeight - BorderWidth;

        if (clientX >= 0 && clientY >= 0 && 
            clientX < Form.Width - (BorderWidth * 2) && 
            clientY < Form.Height - TitleBarHeight - (BorderWidth * 2))
        {
            var args = new Forms.MouseEventArgs(
                MouseButtons.None,
                0,
                clientX,
                clientY
            );
            Form.OnMouseMove(args);
        }
    }

    private void HandleTouchEnd(BlazorTouchEventArgs e)
    {
        if (Form == null) return;

        // Use last touch position stored in HandleTouchStart
        var clientX = (int)_lastTouchX - BorderWidth;
        var clientY = (int)_lastTouchY - TitleBarHeight - BorderWidth;

        if (clientX >= 0 && clientY >= 0 && 
            clientX < Form.Width - (BorderWidth * 2) && 
            clientY < Form.Height - TitleBarHeight - (BorderWidth * 2))
        {
            var args = new Forms.MouseEventArgs(
                MouseButtons.Left,
                1,
                clientX,
                clientY
            );
            Form.OnMouseUp(args);
        }
    }

    // Keyboard events
    private void HandleKeyDown(BlazorKeyboardEventArgs e)
    {
        if (Form == null) return;

        // Update static modifier keys state
        UpdateModifierKeys(e.CtrlKey, e.ShiftKey, e.AltKey);

        var args = new KeyEventArgs(
            ParseKeyCode(e.Code),
            e.AltKey,
            e.CtrlKey,
            e.ShiftKey
        );
        Form.OnKeyDown(args);
    }

    private void HandleKeyUp(BlazorKeyboardEventArgs e)
    {
        if (Form == null) return;

        // Update static modifier keys state
        UpdateModifierKeys(e.CtrlKey, e.ShiftKey, e.AltKey);
        var args = new KeyEventArgs(
            ParseKeyCode(e.Code),
            e.AltKey,
            e.CtrlKey,
            e.ShiftKey
        );
        Form.OnKeyUp(args);
    }

    private void HandleKeyPress(BlazorKeyboardEventArgs e)
    {
        if (Form == null || string.IsNullOrEmpty(e.Key)) return;

        if (e.Key.Length == 1)
        {
            var args = new KeyPressEventArgs(e.Key[0]);
            Form.OnKeyPress(args);
        }
    }

    private void CloseForm()
    {
        Form?.Close();
        StateHasChanged();
    }

    private void MinimizeForm()
    {
        Form?.Minimize();
        StateHasChanged();
    }

    /// <summary>
    /// Updates the static Control.ModifierKeys based on current key state
    /// </summary>
    private void UpdateModifierKeys(bool ctrl, bool shift, bool alt)
    {
        var modifiers = Keys.None;
        if (ctrl) modifiers |= Keys.Control;
        if (shift) modifiers |= Keys.Shift;
        if (alt) modifiers |= Keys.Alt;
        Control.ModifierKeys = modifiers;
    }

    private async Task ToggleMaximize()
    {
        if (Form == null) return;

        // Enable animation for smooth transition
        _enableAnimation = true;
        StateHasChanged();

        if (Form.WindowState == FormWindowState.Maximized)
        {
            Form.Restore();

            // Ensure title bar is visible after restore (important for snap-to-top restore)
            Form.EnsureTitleBarVisible(ViewportWidth, ViewportHeight, TaskbarHeight);
        }
        else
        {
            // Use actual viewport dimensions
            Form.Maximize(ViewportWidth, ViewportHeight, TaskbarHeight);
        }

        // Trigger layout after window state change
        Form.PerformLayout();

        // Force multiple state updates to ensure immediate visual update
        StateHasChanged();
        await Task.Yield(); // Let Blazor process the state change
        StateHasChanged();
        await RenderForm();
        StateHasChanged();

        // Disable animation after transition completes
        await Task.Delay(AnimationDurationMs);
        _enableAnimation = false;
        StateHasChanged();
    }

    // Helper methods
    private MouseButtons GetMouseButton(long button)
    {
        return button switch
        {
            0 => MouseButtons.Left,
            1 => MouseButtons.Middle,
            2 => MouseButtons.Right,
            _ => MouseButtons.None
        };
    }

    private Keys ParseKeyCode(string code)
    {
        return code switch
        {
            "Backspace" => Keys.Back,
            "Tab" => Keys.Tab,
            "Enter" => Keys.Enter,
            "ShiftLeft" or "ShiftRight" => Keys.Shift,
            "ControlLeft" or "ControlRight" => Keys.Control,
            "AltLeft" or "AltRight" => Keys.Alt,
            "Escape" => Keys.Escape,
            "Space" => Keys.Space,
            "PageUp" => Keys.PageUp,
            "PageDown" => Keys.PageDown,
            "End" => Keys.End,
            "Home" => Keys.Home,
            "ArrowLeft" => Keys.Left,
            "ArrowUp" => Keys.Up,
            "ArrowRight" => Keys.Right,
            "ArrowDown" => Keys.Down,
            "Delete" => Keys.Delete,
            "Digit0" => Keys.D0,
            "Digit1" => Keys.D1,
            "Digit2" => Keys.D2,
            "Digit3" => Keys.D3,
            "Digit4" => Keys.D4,
