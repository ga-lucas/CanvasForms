    private class BoundingRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }

    // Viewport tracking
    [Parameter]
    public int ViewportWidth { get; set; } = 1920;

    [Parameter]
    public int ViewportHeight { get; set; } = 1080;

    [Parameter]
    public int TaskbarHeight { get; set; } = 32;

    // Callback to get current max z-index from Desktop
    [Parameter]
    public Func<int>? GetMaxZIndex { get; set; }

    /// <summary>
    /// Ensures the form's title bar is visible within the viewport.
    /// Called after moving, resizing, or viewport changes.
    /// </summary>
    private async Task EnsureFormTitleBarVisible()
    {
        if (Form == null) return;

        Form.EnsureTitleBarVisible(ViewportWidth, ViewportHeight, TaskbarHeight);
        StateHasChanged();
    }

    /// <summary>
    /// Called when viewport size changes (browser resize)
    /// </summary>
    [JSInvokable]
    public async Task OnViewportChanged(int width, int height)
    {
        ViewportWidth = width;
        ViewportHeight = height;
        await EnsureFormTitleBarVisible();
    }

    public void Dispose()
    {
        // Clean up offscreen buffer to free memory
        if (_initialized)
        {
            try
            {
                JSRuntime.InvokeVoidAsync("disposeCanvasBuffer", _canvasRef);
            }
            catch
            {
                // Ignore errors during disposal
            }
        }

        _dotNetRef?.Dispose();
    }
}
